# ─── Servidor ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Banco de Dados (PostgreSQL) ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hsa_chamados
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=mude_para_uma_chave_secreta_longa_e_aleatoria
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ─── E-mail (SMTP) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=chamados@hsa.com.br
SMTP_PASS=sua_senha_de_app
EMAIL_FROM="HSA Chamados <chamados@hsa.com.br>"

# ─── Upload de Arquivos ─────────────────────────────────────
UPLOAD_MAX_SIZE_MB=25
UPLOAD_DIR=./uploads

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── SLA (em minutos) ───────────────────────────────────────
SLA_CRITICA=120
SLA_ALTA=480
SLA_MEDIA=1440
SLA_BAIXA=4320
